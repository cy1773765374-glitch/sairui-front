# Example Nginx site config for openclaw-userlook.
# Copy this file to /etc/nginx/sites-available/openclaw-userlook,
# update server_name, ssl_certificate, ssl_certificate_key, and root,
# then enable it with a symlink into /etc/nginx/sites-enabled/.
#
# This template intentionally proxies only the FastAPI backend on 127.0.0.1:10009.
# Do not proxy or expose OpenClaw Gateway 127.0.0.1:18789.

server {
    listen 80;
    listen [::]:80;
    server_name example.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name example.com;

    ssl_certificate /etc/nginx/ssl/openclaw-userlook/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/openclaw-userlook/privkey.pem;

    client_max_body_size 100m;

    root /opt/openclaw-userlook/frontend/dist;
    index index.html;

    access_log /var/log/nginx/openclaw-userlook.access.log;
    error_log /var/log/nginx/openclaw-userlook.error.log;

    location /api/ws/ {
        proxy_pass http://127.0.0.1:10009;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:10009;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
