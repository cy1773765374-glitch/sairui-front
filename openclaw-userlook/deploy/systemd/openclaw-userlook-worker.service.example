[Unit]
Description=openclaw-userlook background worker placeholder
After=network.target mysql.service openclaw-userlook-backend.service
Wants=network.target

[Service]
Type=simple
User=openclaw
Group=openclaw
WorkingDirectory=/opt/openclaw-userlook/backend
EnvironmentFile=/opt/openclaw-userlook/backend/.env
ExecStart=/bin/bash -lc 'echo "No standalone worker is implemented in Phase 10."; sleep infinity'
Restart=always
RestartSec=5
StandardOutput=append:/opt/openclaw-userlook/backend/logs/worker.log
StandardError=append:/opt/openclaw-userlook/backend/logs/worker.err.log

[Install]
WantedBy=multi-user.target
