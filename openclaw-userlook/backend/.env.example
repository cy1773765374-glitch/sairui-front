APP_NAME=openclaw-userlook-backend
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=10009
OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_GATEWAY_TIMEOUT_SECONDS=300
TASK_CHAT_TIMEOUT_SECONDS=120
TASK_JOB_TIMEOUT_SECONDS=1800
TASK_STALE_RUNNING_MINUTES=30
TASK_WATCHDOG_INTERVAL_SECONDS=60
TASK_AGENT_CONCURRENCY=1
TASK_GLOBAL_CHAT_CONCURRENCY=3
TASK_GLOBAL_JOB_CONCURRENCY=1
MOCK_OPENCLAW=true
DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/openclaw_userlook?charset=utf8mb4
JWT_SECRET_KEY=please-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123456
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_REDIRECT_URI=
WECOM_MOCK_LOGIN=true
WECOM_DEFAULT_USER_STATUS=pending
USER_UPLOAD_ROOT=/data/openclaw-userlook/uploads
USER_OUTPUT_ROOT=/data/openclaw-userlook/outputs
MAX_UPLOAD_MB=50
